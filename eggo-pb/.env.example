# Environment Variables for eggo-pb
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# ============================================
# LINE OAuth Configuration
# ============================================
# Get these from LINE Developers Console:
# https://developers.line.me/console/
LINE_CHANNEL_ID=your_line_channel_id_here
LINE_CHANNEL_SECRET=your_line_channel_secret_here

# ============================================
# Wallet Encryption
# ============================================
# CRITICAL: This key encrypts all private keys
# Generate with: openssl rand -hex 32
# Store securely and back up!
WALLET_MASTER_KEY=development_key_change_in_production_32_chars_min

# ============================================
# Application Configuration
# ============================================
APP_NAME=eggo-pb
APP_URL=http://localhost:8090
NODE_ENV=development

# ============================================
# PocketBase Configuration (optional)
# ============================================
# PB_DATA_DIR=./pb_data
# PB_ENCRYPTION_KEY=optional_additional_encryption_key

# ============================================
# Security Notes
# ============================================
# 1. Never commit this file to git
# 2. Use different keys for dev/staging/production
# 3. Keep WALLET_MASTER_KEY secure - if lost, private keys are unrecoverable
# 4. Back up WALLET_MASTER_KEY in secure password manager
# 5. Rotate keys periodically in production
